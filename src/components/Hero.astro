---
import AsciiBrain from "@/components/AsciiBrain.astro";
import { FULL_NAME, QUOTE } from "@/consts";

const [firstName, ...restNameParts] = FULL_NAME.split(" ");
const restName = restNameParts.join(" ");
---

<div class="hero-bg hidden md:block h-screen hero-bg-animate absolute top-0">
</div>
<section class="home-hero !z-[20] relative w-full" id="hero">
  <div class="home-hero-copy">
    <div class="home-hero-title-block">
      <h1 class="home-hero-title font-bold">
        <span class="home-hero-title-line">{`<${firstName} `}</span>
        <span class="home-hero-title-line">{`${restName} />`}</span>
      </h1>
      <h2 class="home-hero-subtitle opacity-95">
        {QUOTE}
      </h2>
    </div>
  </div>
  <div class="home-hero-art">
    <AsciiBrain />
  </div>
</section>

<script is:inline>
  const hero_bg = document.querySelector(".hero-bg-animate");

  setInterval(() => {
    let binaryText = "";
    for (let i = 0; i < 1000; i++) {
      binaryText += Math.floor(Math.random() * 2).toString();
    }
    hero_bg.textContent = binaryText;
  }, 300);
</script>
