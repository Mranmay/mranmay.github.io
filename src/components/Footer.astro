---
import { FULL_NAME, PROFILE_LINKS } from "@/consts";

const today = new Date();
---

<section
  id="footer"
  class="font-terminal relative grid w-full place-items-center border-t border-white/10 bg-white/[0.01] px-6 py-8 text-center text-sm"
>
  <div
    class="flex max-w-6xl flex-col items-center gap-4 md:flex-row md:justify-between"
  >
    <p class="text-white/65">&copy; {today.getFullYear()} {FULL_NAME}</p>
    <nav class="flex flex-wrap justify-center gap-3 text-white/65">
      {
        PROFILE_LINKS.map((link) => (
          <a
            href={link.href}
            class="transition-colors hover:text-white"
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noreferrer" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</section>
