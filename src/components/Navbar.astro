---
import { SITE_TITLE, NAV_LINKS as links } from "@/consts";
---

<nav class="site-nav w-full !z-[9999] py-5 px-4 backdrop-blur-sm">
  <div
    class="w-full grid gap-4 md:px-5 place-items-center grid-cols-1 md:flex md:justify-between md:px-4"
  >
    <a href="/">
      <div
        id="logo"
        class="site-logo pt-2 pb-1 !grid !place-items-center select-none leading-none scale-110 px-4 transition-all ease-in-out"
      >
        {SITE_TITLE}
      </div>
    </a>
    <div class="site-nav-links flex flex-wrap gap-4 md:pr-5">
      <div class="hidden md:block">/</div>
      {
        links.map((link) => {
          const href =
            link.href ?? link.title.toLowerCase().replaceAll(" ", "-");
          const target = href.startsWith("/") ? href : `/${href}`;
          const pathname = Astro.url.pathname.replace(
            import.meta.env.BASE_URL,
            "",
          );
          const subpath = pathname.match(/[^\/]+/g);
          const isActive =
            target === pathname || target === "/" + (subpath?.[0] || "");
          return (
            <>
              <a
                class:list={[{ "is-active": isActive }]}
                class="site-nav-link transition-all ease-in-out px-2 max-w-fit"
                href={target}
              >
                <div>{link.title}</div>
              </a>
              <div class="hidden md:block">/</div>
            </>
          );
        })
      }
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle color scheme"
        aria-pressed="false"
        data-theme-toggle
      >
        <span class="theme-toggle-track" aria-hidden="true">
          <span class="theme-toggle-thumb">
            <span class="theme-toggle-moon">☾</span>
            <span class="theme-toggle-sun">☀</span>
          </span>
        </span>
        <span class="sr-only" data-theme-toggle-label>Switch theme</span>
      </button>
    </div>
  </div>
</nav>
