---
import { SITE_TITLE, NAV_LINKS as links } from "@/consts";
---

<nav class="site-nav w-full !z-[9999] py-5 px-4 backdrop-blur-sm">
  <div
    class="w-full grid gap-4 md:px-5 place-items-center grid-cols-1 md:flex md:justify-between md:px-4"
  >
    <a href="/">
      <div
        id="logo"
        class="site-logo pt-2 pb-1 !grid !place-items-center select-none leading-none scale-110 px-4 transition-all ease-in-out"
      >
        {SITE_TITLE}
      </div>
    </a>
    <div class="site-nav-links flex flex-wrap gap-4 md:pr-5">
      <div class="hidden md:block">/</div>
      {
        links.map((link) => {
          const href =
            link.href ?? link.title.toLowerCase().replaceAll(" ", "-");
          const target = href.startsWith("/") ? href : `/${href}`;
          const pathname = Astro.url.pathname.replace(
            import.meta.env.BASE_URL,
            "",
          );
          const subpath = pathname.match(/[^\/]+/g);
          const isActive =
            target === pathname || target === "/" + (subpath?.[0] || "");
          return (
            <>
              <a
                class:list={[{ "is-active": isActive }]}
                class="site-nav-link transition-all ease-in-out px-2 max-w-fit"
                href={target}
              >
                <div>{link.title}</div>
              </a>
              <div class="hidden md:block">/</div>
            </>
          );
        })
      }
      <button
        id="theme-toggle"
        class="theme-toggle transition-all ease-in-out px-2"
        type="button"
        aria-label="Switch to light mode"
        title="Toggle theme"
      >
        dark
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  const updateLogoState = () => {
    const logo = document.getElementById("logo");
    if (!logo) return;
    if (window.scrollY > 100) {
      logo.classList.add("is-scrolled");
    } else {
      logo.classList.remove("is-scrolled");
    }
  };

  const setupThemeToggle = () => {
    const toggle = document.getElementById("theme-toggle");
    if (!toggle || toggle.dataset.bound === "true") return;
    toggle.dataset.bound = "true";

    const syncToggle = () => {
      const theme = document.documentElement.dataset.theme || "dark";
      const isLight = theme === "light";
      toggle.textContent = isLight ? "light" : "dark";
      toggle.setAttribute(
        "aria-label",
        isLight ? "Switch to dark mode" : "Switch to light mode",
      );
      toggle.setAttribute("aria-pressed", String(isLight));
    };

    toggle.addEventListener("click", () => {
      const nextTheme =
        document.documentElement.dataset.theme === "light" ? "dark" : "light";
      document.documentElement.dataset.theme = nextTheme;
      try {
        localStorage.setItem("theme", nextTheme);
      } catch {
        // Ignore storage failures; the active page theme still updates.
      }
      syncToggle();
    });

    syncToggle();
  };

  window.addEventListener("scroll", updateLogoState);
  document.addEventListener("astro:page-load", () => {
    updateLogoState();
    setupThemeToggle();
  });

  updateLogoState();
  setupThemeToggle();
</script>
