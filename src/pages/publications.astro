---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { FULL_NAME } from "@/consts";

const publications = [
  {
    title:
      "Ensemble learning and EigenCAM-based feature analysis for improving the performance and explainability of object detection in drone imagery",
    authors:
      "Gargi Joshi, Amey Joshi, Mranmay Shetty, Rahee Walambe, Ketan Kotecha, Fabio Scotti, Vincenzo Piuri",
    venue: "Discover Applied Sciences, 2025",
  },
  {
    title: "Human or Machine? Turing Tests for Language Tasks",
    authors:
      "Mengmi Zhang, Giorgia Dellaferrera, Ankur Sikarwar, Marcelo Armendariz, Noga Mudrik, Prachi Agrawal, Spandan Madan, Mranmay Shetty, Andrei Barbu, Hanspeter Pfister, Gabriel Kreiman, and others",
    venue: "Nature Human Behaviour, 2026",
  },
];

const inReview = [
  {
    title:
      "From Neural Signals to Images: Generative Reconstruction of Visual Stimuli from Electroencephalography Signals",
    authors:
      "Rahee Walambe, Akshay Kushwaha, Divya Shah, Mranmay Shetty, Vaibhav Tasgaonkar, Ketan Kotecha, Sultan Alfarhood",
    venue: "Submitted — under review",
  },
  {
    title:
      "Machine Learning-Powered Depression Detection: Leveraging Digital Biomarkers for Enhanced Diagnosis and Future Prospects",
    authors:
      "Rahee Walambe, Anil Rahate, Rajanikant Ghate, Vaibhav Tasgaonkar, Mranmay Shetty, Sumiti Saharan, Nayan Kalnad, Ketan Kotecha, Ajith Abraham, Ganesashree Selvachandran",
    venue: "Submitted — under review",
  },
];
---

<Layout
  title={`Publications | ${FULL_NAME}`}
  description="Publications and in-review work by Mranmay Shetty."
>
  <Section title="Publications">
    <div class="mx-auto max-w-5xl">
      <p class="mb-8 text-center text-lg text-white/80">
        Unpublished and in-review work is listed separately from published
        papers.
      </p>

      <h2 class="mb-5 text-3xl">Journal &amp; Conference Papers:</h2>
      <div class="space-y-5">
        {
          publications.map((item) => (
            <article class="border-2 border-white p-5">
              <h3 class="text-2xl">{item.title}</h3>
              <p class="mt-3 text-white/80">{item.authors}</p>
              <p class="mt-3 text-white/65">{item.venue}</p>
            </article>
          ))
        }
      </div>

      <h2 class="mb-5 mt-12 text-3xl">In Review:</h2>
      <div class="space-y-5">
        {
          inReview.map((item) => (
            <article class="border-2 border-white p-5">
              <h3 class="text-2xl">{item.title}</h3>
              <p class="mt-3 text-white/80">{item.authors}</p>
              <p class="mt-3 text-white/65">{item.venue}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Section>
</Layout>
