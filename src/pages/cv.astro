---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { FULL_NAME } from "@/consts";

const education = [
  {
    place:
      "École Polytechnique de l'Université Côte d'Azur, Sophia-Antipolis, France",
    degree: "M.S. in Modeling for Neuronal and Cognitive Systems",
    date: "Sep 2024 – Aug 2026 expected",
  },
  {
    place: "Symbiosis International University, Pune, India",
    degree: "B.Tech. in Electronics and Tele-communication Engineering",
    date: "Aug 2019 – Jun 2023",
  },
];

const researchExperience = [
  {
    role: "Research Intern",
    place:
      "Italian Institute of Technology, Center for Neuroscience and Cognitive Systems",
    date: "Mar 2026 – ongoing",
    bullets: [
      "Investigating rules of dendritic connectivity and compartment-specific visual processing using the MICRONS functional connectomics dataset and whole-dendritic-tree synaptic recordings.",
      "Developing analysis pipelines for two-photon calcium / glutamate imaging, neuronal morphology and connectivity reconstruction, and computational models of dendritic and circuit mechanisms in visual cortex.",
    ],
  },
  {
    role: "Research Intern",
    place: "CNRS - INT Marseille and INRIA - BIOVISION",
    date: "Sep 2025 – Feb 2026",
    bullets: [
      "Building a reproducible pipeline for large-scale two-photon calcium imaging and benchmarking analysis packages such as Suite2p, CaImAn, and CASCADE.",
      "Extracting spatiotemporal spiking motifs and population codes to relate motifs to stimuli and behavior.",
    ],
  },
  {
    role: "Research Intern / Collaborator",
    place: "Harvard Medical School - Kreiman Lab",
    date: "Jan 2023 – present",
    bullets: [
      "Joined as a remote research intern running experiments using large language models to assess Turing-test-style language capabilities.",
      "Executed online behavioral experiments using PsiTurk for data collection.",
      "Continuing part-time remote collaboration developing computational models of working memory.",
    ],
  },
  {
    role: "Research Intern",
    place: "INRIA - BIOVISION Team",
    date: "Mar 2025 – May 2025",
    bullets: [
      "Reviewed literature on the retina and artificial intelligence models that attempt to mimic retinal behavior.",
      "Synthesized findings across studies to understand the state of the art in using AI to model and understand retinal processing.",
    ],
  },
  {
    role: "DST Funded Researcher",
    place:
      "University of Milan, Italy and Symbiosis Institute of Technology, India",
    date: "Jun 2022 – Jun 2023",
    bullets: [
      "Collaborated on a DST-funded Indo-Italian research project on multimodal explainability for object detection and image processing in drone imagery.",
      "Built multimodal machine-learning models for object detection and explainable AI models emphasizing feature importance.",
    ],
  },
  {
    role: "Artificial Intelligence Research Intern",
    place: "Avegen Healthcare",
    date: "Jan 2022 – Jun 2022",
    bullets: [
      "Conducted analysis and market survey on sensor mechanisms for affective-disorder detection.",
      "Developed multimodal AI models using smartphone sensors for stress and depression detection.",
      "Engineered machine-learning and deep-learning models using datasets such as StudentLife and Depresjon.",
    ],
  },
  {
    role: "Undergraduate Researcher",
    place: "Symbiosis Centre for Applied AI, Pune, India",
    date: "Jan 2021 – Jan 2024",
    bullets: [
      "Selected as one of two interns from sophomore students.",
      "Worked on Extreme Learning Machine models with competitive performance and reduced training time.",
      "Explored EEG-based depression detection using the MODMA dataset and MNE-Python.",
      "Assisted in collecting EEG data to natural stimuli for GAN-based reconstruction of images from neural data.",
    ],
  },
];

const skills = [
  {
    title: "Programming",
    text: "Python, R, MATLAB, JavaScript / TypeScript basics",
  },
  {
    title: "Machine Learning",
    text: "PyTorch, classical machine learning, deep learning, representation analysis",
  },
  {
    title: "Neurodata / Analysis",
    text: "Suite2p, CaImAn, CASCADE, MNE-Python, MICRONS, CAVEclient, calcium imaging, spike deconvolution, connectomics",
  },
  {
    title: "Tools & Platforms",
    text: "Git, Linux / Ubuntu, Jupyter, Google Cloud Platform, Visual Studio Code, PyCharm",
  },
];

const miscellaneous = [
  {
    title: "Scholarships & Awards",
    date: "",
    bullets: [
      "Neuromod Excellence Scholarship 2025: excellence scholarship awarded to top first-year students by the Neuromod Institute.",
      "Master Mobility Scholarship Program 2026: awarded to second-year Master's students undertaking an internship abroad, based on excellence, project quality, and financial need.",
    ],
  },
  {
    title: "Graphic Design Volunteer",
    place: "IGiftLife",
    date: "Jan 2022 – May 2022",
    bullets: [
      "Created social media posts to raise awareness about organ donation in India.",
      "Designed content series such as Historical Facts, Heartwarming Headlines, Religions on Organ Donation, and Key Stats.",
      "Curated content to spread awareness and counter myths related to organ donation.",
    ],
  },
  {
    title: "Professional E-Athlete",
    place: "Various Esports Organizations",
    date: "Oct 2019 – Dec 2020",
    bullets: [
      "Played Call of Duty and PUBG competitively for different teams.",
      "Finished last season as part of one of the top 10 teams in South Asia and was mentioned on Liquipedia.",
    ],
  },
];
---

<Layout title={`CV | ${FULL_NAME}`} description="Web CV for Mranmay Shetty.">
  <Section title="Education">
    <div class="mx-auto max-w-5xl space-y-6">
      {
        education.map((item) => (
          <article class="grid gap-2 border-2 border-white p-5 md:grid-cols-[1fr_14rem]">
            <div>
              <h2 class="text-2xl">{item.degree}</h2>
              <p class="mt-2 text-white/80">{item.place}</p>
            </div>
            <p class="text-left text-white/70 md:text-right">{item.date}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Research Experience">
    <div class="mx-auto max-w-5xl space-y-6">
      {
        researchExperience.map((item) => (
          <article class="border-2 border-white p-5">
            <div class="grid gap-2 md:grid-cols-[1fr_14rem]">
              <div>
                <h2 class="text-2xl">{item.role}</h2>
                <p class="mt-2 text-white/80">{item.place}</p>
              </div>
              <p class="text-left text-white/70 md:text-right">{item.date}</p>
            </div>
            <ul class="mt-5 list-disc space-y-3 pl-6 text-white/85">
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Technical Skills">
    <div class="mx-auto max-w-5xl grid gap-4 md:grid-cols-2">
      {
        skills.map((skill) => (
          <article class="border-2 border-white p-5">
            <h2 class="text-2xl">{skill.title}</h2>
            <p class="mt-3 text-white/85">{skill.text}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Miscellaneous">
    <div class="mx-auto max-w-5xl space-y-6">
      {
        miscellaneous.map((item) => (
          <article class="border-2 border-white p-5">
            <div class="grid gap-2 md:grid-cols-[1fr_14rem]">
              <div>
                <h2 class="text-2xl">{item.title}</h2>
                {item.place && <p class="mt-2 text-white/80">{item.place}</p>}
              </div>
              {item.date && (
                <p class="text-left text-white/70 md:text-right">{item.date}</p>
              )}
            </div>
            <ul class="mt-5 list-disc space-y-3 pl-6 text-white/85">
              {item.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </Section>
</Layout>
